{
  "name": "@equitherm/core",
  "version": "0.1.0",
  "description": "Pure calculation library for equitherm heating curves and PID control",
  "author": "P4uLT",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/equitherm/core.git"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "typescript": "^5.9.3",
    "vitest": "^2.0.0"
  },
  "packageManager": "pnpm@10.30.3"
}
